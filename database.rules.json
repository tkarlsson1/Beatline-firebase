{
  "rules": {
    ".read": false,
    ".write": false,
    "games": {
      ".read": true,
      ".write": true
    },
    "reportedTracks": {
      ".read": "auth != null && auth.uid == 'rtEO2DAFwfM4KdujZrFblspbwpu1'",
      ".write": true
    },
    "flaggedTracks": {
      ".read": "auth != null && auth.uid == 'rtEO2DAFwfM4KdujZrFblspbwpu1'",
      ".write": true
    },
    "standardLists": {
      ".read": true,
      ".write": "auth != null && auth.uid == 'rtEO2DAFwfM4KdujZrFblspbwpu1'",
      "$listId": {
        ".validate": "newData.hasChildren(['songs'])"
      }
    },
    "verifiedTracks": {
      ".read": true,
      ".write": "auth != null && auth.uid == 'rtEO2DAFwfM4KdujZrFblspbwpu1'"
    },
    "users": {
      ".read": "auth != null && auth.uid == 'rtEO2DAFwfM4KdujZrFblspbwpu1'",
      ".write": "auth != null && auth.uid == 'rtEO2DAFwfM4KdujZrFblspbwpu1'",
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "userPlaylists": {
      ".read": "auth != null && auth.uid == 'rtEO2DAFwfM4KdujZrFblspbwpu1'",
      ".write": "auth != null && auth.uid == 'rtEO2DAFwfM4KdujZrFblspbwpu1'",
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "$playlistId": {
          ".validate": "newData.hasChildren(['songs'])"
        }
      }
    }
  }
}
